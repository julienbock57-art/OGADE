tiple'.Container26_3.Form9_3","member":"Item"}}],"properties":{"level":"Medium"}},{"ruleId":"app-InefficientDelayLoading","ruleIndex":18,"message":{"id":"issue"},"locations":[{"physicalLocation":{"address":{"relativeAddress":0,"fullyQualifiedName":"'Validation maquettes_multiple'.Container26_2.Form9_2.Item"}},"logicalLocations":[{"fullyQualifiedName":"'Validation maquettes_multiple'.Container26_2.Form9_2.Item"}],"properties":{"module":"Validation maquettes_multiple","type":"'Validation maquettes_multiple'.Container26_2.Form9_2","member":"Item"}}],"properties":{"level":"Medium"}}],"tool":{"driver":{"name":"PowerApps app checker","fullName":"PowerApps app checker","version":"1.348","rules":[{"id":"app-ErrInvalidName","messageStrings":{"issue":{"text":"Name isn't valid. '{0}' isn't recognized."}},"properties":{"howToFix":["Remove or correct the reference to the name that isn't valid."],"whyFix":"","level":"High","componentType":"app","primaryCategory":"formula"}},{"id":"app-ErrInvalidDot","messageStrings":{"issue":{"text":"The '.' operator cannot be used on {0} values."}},"properties":{"whyFix":"","level":"High","componentType":"app","primaryCategory":"formula"}},{"id":"app-ErrIncompatibleTypesForEquality-Left-Right","messageStrings":{"issue":{"text":"Incompatible types for comparison. These types can't be compared: {0}, {1}."}},"properties":{"howToFix":["You might need to convert the value to be the same type, such as converting a date string (e.g., \"12/31/2018\") to a date value.","If you're comparing records or tables, the field or column types must match exactly."],"whyFix":"","level":"High","componentType":"app","primaryCategory":"formula"}},{"id":"app-ErrVariableMustHaveType","messageStrings":{"issue":{"text":"No type found for variable '{0}'. Ensure that it is Set to a non-Blank value somewhere in the app."}},"properties":{"whyFix":"","level":"High","componentType":"app","primaryCategory":"formula"}},{"id":"app-ErrInvalidArgs-Func","messageStrings":{"issue":{"text":"The function '{0}' has some invalid arguments."}},"properties":{"whyFix":"","level":"High","componentType":"app","primaryCategory":"formula"}},{"id":"app-SuggestRemoteExecutionHint","messageStrings":{"issue":{"text":"Delegation warning. The \"{0}\" part of this formula might not work correctly on large data sets."}},"properties":{"howToFix":["If your data set exceeds the 500 record limit but contains less than 2,000 records, try resetting the limit.","Try simplifying the formula.","Try moving your data to a different data source."],"whyFix":"","level":"Medium","componentType":"app","primaryCategory":"formula"}},{"id":"app-SuggestRemoteExecutionHint-OpNotSupportedByService","messageStrings":{"issue":{"text":"Delegation warning. The highlighted part of this formula might not work correctly on large data sets. The \"{0}\" operation is not supported by this connector."}},"properties":{"howToFix":["If your data set exceeds the 500 record limit but contains less than 2,000 records, try resetting the limit.","Try simplifying the formula.","Try moving your data to a different data source."],"whyFix":"","level":"Medium","componentType":"app","primaryCategory":"formula"}},{"id":"app-SuggestRemoteExecutionHint-OpNotSupportedByColumn","messageStrings":{"issue":{"text":"Delegation warning. The highlighted part of this formula might not work correctly with column \"{0}\" on large data sets."}},"properties":{"howToFix":["If your data set exceeds the 500 record limit but contains less than 2,000 records, try resetting the limit.","Try simplifying the formula.","Try moving your data to a different data source."],"whyFix":"","level":"Medium","componentType":"app","primaryCategory":"formula"}},{"id":"app-ErrColumnDoesNotExist-Name-Similar","messageStrings":{"issue":{"text":"The specified column '{0}' does not exist. The column with the most similar name is '{1}'."}},"properties":{"whyFix":"","level":"High","componentType":"app","primaryCategory":"formula"}},{"id":"app-ErrIncompatibleRulePropTypes-PropKind-RuleKind","messageStrings":{"issue":{"text":"Expected {0} value."}},"properties":{"howToFix":["Change the rule to produce a {0} value."],"whyFix":"","level":"High","componentType":"app","primaryCategory":"formula"}},{"id":"app-SuggestRemoteExecutionHint-InOpRhs","messageStrings":{"issue":{"text":"Delegation warning. The highlighted part of this formula might not work correctly on large data sets."}},"properties":{"howToFix":["Change the item to the right of the \"in\" operator to be a column from the correct data source.","If your data set exceeds the 500 record limit but contains less than 2,000 records, try resetting the limit.","Try simplifying the formula.","Try moving your data to a different data source."],"whyFix":"","level":"Medium","componentType":"app","primaryCategory":"formula"}},{"id":"acc-AccessibleLabelNeeded","messageStrings":{"issue":{"text":"Missing accessible label"}},"properties":{"howToFix":["Edit the accessible label property to describe the item."],"whyFix":"If there's no accessible text, people who can’t see the screen won't understand what’s in images and controls.","level":"Medium","componentType":"app","primaryCategory":"accessibility"}},{"id":"acc-ReadableScreenNameNeeded","messageStrings":{"issue":{"text":"Revise screen name"}},"properties":{"howToFix":["Give the screen  a title that describes what's on the screen or what it's used for."],"whyFix":"People who are blind, have low vision, or a reading disability rely on screen titles to navigate using the screen reader. ","level":"Low","componentType":"app","primaryCategory":"accessibility"}},{"id":"acc-TabIndexShouldBeDefinedForInteractiveControl","messageStrings":{"issue":{"text":"Missing tab stop"}},"properties":{"howToFix":["Set TabIndex to 0 or greater to ensure that interactive elements have a tab stop."],"whyFix":"People who use the keyboard with your app will not be able to access this element without a tab stop.","level":"Medium","componentType":"app","primaryCategory":"accessibility"}},{"id":"acc-FocusBorderShouldBeVisible","messageStrings":{"issue":{"text":"Focus isn't showing"}},"properties":{"howToFix":["Change the FocusedBorderThickness property to be more than 0."],"whyFix":"If the focus isn't visible, people who don't use a mouse won't be able to see it when they're interacting with the app.","level":"Medium","componentType":"app","primaryCategory":"accessibility"}},{"id":"app-UnusedVariables","messageStrings":{"issue":{"text":"Variable non utilisée"}},"properties":{"howToFix":["Supprimez la variable inutilisée."],"whyFix":"Cette variable est déclarée, mais n'est référencée par aucun contrôle. Elle est donc inutile.","componentType":"app","primaryCategory":"performance","level":"Medium"}},{"id":"app-UnusedMediaResources","messageStrings":{"issue":{"text":"Fichiers multimédias inutilisés"}},"properties":{"howToFix":["Supprimez le fichier multimédia inutilisé dans le volet Media."],"whyFix":"Ce fichier multimédia n’est référencé par aucune formule de contrôle. Il n’est donc pas nécessaire. Si vous le supprimez, les performances seront améliorées.","componentType":"app","primaryCategory":"performance","level":"Medium"}},{"id":"app-DataSourceDefaultMaxRowsLimit","messageStrings":{"issue":{"text":"La limite de lignes de données pour les requêtes non délégables est supérieure à 500"}},"properties":{"howToFix":["Mettez à jour la « limite de lignes de données pour les requêtes non délégables » dans les paramètres avancés de l'application."],"whyFix":"Une « limite de ligne de données » supérieure à 500 peut ralentir l'application en cas d'exécution de requêtes non délégables, car l'application doit traiter chaque ligne elle-même au lieu d'exécuter la requête sur le serveur.","componentType":"app","primaryCategory":"performance","level":"Medium"}},{"id":"app-InefficientDelayLoading","messageStrings":{"issue":{"text":"Chargement différé inefficace"}},"properties":{"howToFix":["Utilisez plutôt des variables, des collections et un contexte de navigation pour partager l'état sur les différents écrans."],"whyFix":"Les contrôles qui référencent des contrôles sur d’autres écrans peuvent ralentir le chargement et la navigation de l’application, car ils peuvent forcer l’application à charger les autres écrans immédiatement au lieu d’attendre que l’utilisateur y accède.","componentType":"app","primaryCategory":"performance","level":"Medium"}},{"id":"app-TextInputIsNotDelayOutput","messageStrings":{"issue":{"text":"Entrée de texte inefficace"}},"properties":{"howToFix":["Activez la propriété DelayOutput du contrôle d'entrée de texte."],"whyFix":"Quand un contrôle d’entrée de texte a trop de contrôles qui dépendent de sa valeur, la saisie dans cette entrée peut ralentir l’application. Définissez DelayOutput sur true pour éviter ce problème en mettant à jour uniquement les contrôles dépendants à l’arrêt de la saisie.","componentType":"app","primaryCategory":"performance","level":"Medium"}},{"id":"app-ScreenHasManyControls","messageStrings":{"issue":{"text":"Trop de contrôles sur un écran"}},"properties":{"howToFix":["Réduisez le nombre de contrôles à l'écran.","Divisez l'application en plusieurs écrans pour réduire la complexité de chaque écran.","Utilisez des composants pour unifier les contrôles regroupés qui sont identiques sur les écrans et ainsi réduire la duplication.","Utilisez des galeries pour représenter une série de contrôles similaires répétés.","Décomposez l'application en plusieurs petites applications performantes."],"whyFix":"Chaque contrôle consomme des ressources, et une application peut ralentir ou cesser de répondre si un écran a trop de contrôles. La complexité estimée de « Screen5 » est 412, ce qui dépasse le seuil maximal recommandé (300).","componentType":"app","primaryCategory":"performance","level":"Medium"}},{"id":"app-NumericPropertySizeWarning","messageStrings":{"issue":{"text":"Autorisation de chargement de grands fichiers jusqu'à 10 Mo"}},"properties":{"howToFix":["Déterminez si vous avez besoin de pièces jointes de cette taille."],"whyFix":"Nous vous recommandons d'effectuer des tests sur toutes les plateformes prises en charge pour garantir le chargement des pièces jointes de cette taille.","componentType":"app","primaryCategory":"performance","level":"Low"}}]}},"invocations":[{"executionSuccessful":true}],"columnKind":"utf16CodeUnits"}]}